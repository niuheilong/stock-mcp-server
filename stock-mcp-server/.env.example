# 青龙 Stock MCP Server - 环境变量配置
# 复制此文件为 .env 并填写你的配置

# ============================================
# API密钥配置 (可选，用于扩展功能)
# ============================================

# 新浪财经API (如需使用高级功能)
# SINA_API_KEY=your_key_here

# 雪球Cookie (用于获取社交媒体情绪)
# XUEQIU_COOKIE=your_cookie_here

# 阿里云市场API Key (用于财经新闻)
# ALICLOUD_API_KEY=your_key_here

# 聚合数据API Key (用于新闻数据)
# JUHE_API_KEY=your_key_here

# ============================================
# 请求控制
# ============================================

# 请求间隔 (秒)，防止被封
REQUEST_INTERVAL=1

# 最大重试次数
MAX_RETRIES=3

# 请求超时 (秒)
REQUEST_TIMEOUT=10

# ============================================
# 缓存配置
# ============================================

# 是否启用缓存
CACHE_ENABLED=true

# 缓存时间 (秒)
CACHE_TTL=300

# ============================================
# 日志配置
# ============================================

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================
# 服务器配置
# ============================================

# 服务端口
SERVER_PORT=8000

# 服务主机
SERVER_HOST=0.0.0.0

# ============================================
# 股票监控配置
# ============================================

# 自选股列表 (逗号分隔)
# STOCK_WATCHLIST=sh600410,sh600620,sh603986,sh688525,sz002261,sz300428,sh688629

# 数据更新间隔 (秒)
UPDATE_INTERVAL=60
